<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Create Project</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
body {
    background-color: #f0f2f5;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.page-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: bold;
    margin-top: 50px;
    margin-bottom: 20px;
    color: #333;
}

.create-card {
    background-color: white;
    padding: 40px;
    max-width: 900px;
    margin: 20px auto 50px auto; /* leave space above for heading */
    border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

.btn-lg {
    min-width: 200px;
}

.create-image {
    max-width: 400px;
    display: block;
    margin: 30px auto 0 auto;
    border-radius: 10px;
}
</style>
</head>

<body>

<!-- Heading above the card -->
<div class="page-title">Create New Project</div>

<div class="create-card">
  <form action="/create" method="POST">

    <!-- Project Title -->
    <div class="mb-3">
      <label class="form-label">Project Title</label>
      <input type="text" class="form-control" name="title" placeholder="Enter project title" required>
    </div>

    <!-- Project Description -->
    <div class="mb-3">
      <label class="form-label">Project Description</label>
      <textarea class="form-control" name="description" rows="5" placeholder="Enter project description" required></textarea>
    </div>

    <!-- Project Category -->
    <div class="mb-3">
      <label class="form-label">Project Category</label>
      <select name="category" class="form-select" required>
        <option value="School">School</option>
        <option value="Work">Work</option>
        <option value="Personal">Personal</option>
        <option value="Web Development">Web Development</option>
      </select>
    </div>

    <!-- Project Status -->
    <div class="mb-3">
      <label class="form-label">Project Status</label>
      <select name="status" class="form-select" required>
        <option value="Active">Active</option>
        <option value="Draft">Draft</option>
        <option value="Completed">Completed</option>
      </select>
    </div>

    <!-- Submit Button -->
    <div class="text-center mb-3">
      <button class="btn btn-primary btn-lg" type="submit">Create Project</button>
    </div>

    <!-- Image -->
    <div class="text-center mb-4">
      <img src="/images/Create.webp" class="create-image" alt="Create Project Image">
    </div>

    <!-- Back Home -->
    <div class="text-center">
      <a href="/" class="btn btn-secondary btn-lg">Back Home</a>
    </div>

  </form>
</div>

</body>
</html>