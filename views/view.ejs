
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>View Project</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
body {
  background-color: #f0f2f5;
}

.page-header {
  text-align: center;
  margin-top: 50px;
  margin-bottom: 20px;
}

.view-card {
  background-color: white;
  padding: 40px;
  max-width: 900px;
  margin: 20px auto 50px auto;
  border-radius: 15px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  text-align: center;
}

.project-image {
  max-width: 45%;
  margin: 10px;
  border-radius: 10px;
  cursor: pointer;
  transition: transform 0.2s;
}

.project-image:hover {
  transform: scale(1.05);
}

.info-row {
  margin-top: 15px;
  font-size: 1.1rem;
}
</style>
</head>

<body>

<!-- PAGE HEADER -->
<div class="page-header">
  <h1>Project Details</h1>
</div>

<!-- WHITE CARD -->
<div class="view-card">

  <h3 class="fw-bold mb-3"><%= work.title %></h3>
  <p class="text-muted mb-4"><%= work.description %></p>

  <!-- STATUS -->
  <div class="info-row">
    <strong>Status:</strong>
    <span class="badge
      <%= work.status === 'Active' ? 'bg-success'
      : work.status === 'Draft' ? 'bg-secondary'
      : 'bg-primary' %>">
      <%= work.status %>
    </span>
  </div>

  <!-- CATEGORY -->
  <div class="info-row">
    <strong>Category:</strong> <%= work.category || "General" %>
  </div>

  <!-- CREATED DATE -->
  <div class="info-row">
    <strong>Created:</strong> <%= new Date(work.createdAt).toLocaleDateString() %>
  </div>

  <!-- IMAGES -->
  <div class="mt-4">
    <img src="/images/Edit1.jpg" class="project-image" alt="Project Image 1">
    <img src="/images/Edit2.jpg" class="project-image" alt="Project Image 2">
  </div>

  <!-- BUTTONS -->
  <div class="mt-4">
    <a href="/" class="btn btn-secondary btn-lg me-2">Back Home</a>
    <a href="/edit/<%= work._id %>" class="btn btn-warning btn-lg">Edit</a>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>