<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Project</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background-color: #f0f2f5;
    }

    .page-header {
      text-align: center;
      margin-top: 50px;
      margin-bottom: 20px;
    }

    .edit-card {
      background-color: white;
      padding: 40px;
      max-width: 900px;
      margin: 20px auto 50px auto;
      border-radius: 15px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .image-row img {
      max-width: 45%;
      margin: 10px;
      border-radius: 10px;
      display: inline-block;
      cursor: pointer;
      transition: transform 0.2s;
    }

    .image-row img:hover {
      transform: scale(1.05);
    }

    .btn-lg {
      min-width: 200px;
    }
  </style>
</head>
<body>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <h1>Edit Project</h1>
  </div>

  <!-- WHITE CARD -->
  <div class="edit-card">

    <form action="/edit/<%= work.id %>" method="POST">
      <div class="mb-3">
        <label for="title" class="form-label">Project Title</label>
        <input type="text" class="form-control" id="title" name="title" value="<%= work.title %>" required>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Project Description</label>
        <textarea class="form-control" id="description" name="description" rows="5" required><%= work.description %></textarea>
      </div>
<!-- STATUS FIELD (NEW) -->
<div class="mb-3">
  <label for="status" class="form-label">Project Status</label>
  <select name="status" id="status" class="form-select">
    <option value="Active" <%= work.status === "Active" ? "selected" : "" %>>Active</option>
    <option value="Draft" <%= work.status === "Draft" ? "selected" : "" %>>Draft</option>
    <option value="Completed" <%= work.status === "Completed" ? "selected" : "" %>>Completed</option>
  </select>
</div>
<div class="mb-3">
<label for="category" class="form-label">Project Category</label>

<select name="category" id="category" class="form-select">

<option value="School" <%= work.category === "School" ? "selected" : "" %>>
School
</option>

<option value="Work" <%= work.category === "Work" ? "selected" : "" %>>
Work
</option>

<option value="Personal" <%= work.category === "Personal" ? "selected" : "" %>>
Personal
</option>

<option value="Web Development" <%= work.category === "Web Development" ? "selected" : "" %>>
Web Development
</option>

</select>
</div>
      <!-- Clickable images -->
      <div class="image-row text-center mb-4">
        <img src="/images/Edit1.jpg" alt="Edit Image 1" data-bs-toggle="modal" data-bs-target="#imageModal1">
        <img src="/images/Edit2.jpg" alt="Edit Image 2" data-bs-toggle="modal" data-bs-target="#imageModal2">
      </div>

      <div class="text-center mb-3">
        <button class="btn btn-primary btn-lg" type="submit">Update Project</button>
      </div>

      <div class="text-center">
        <a href="/" class="btn btn-secondary">Back Home</a>
      </div>
    </form>
  </div>

  <!-- Modal for Image 1 -->
  <div class="modal fade" id="imageModal1" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content bg-transparent border-0">
        <img src="/images/Edit1.jpg" class="img-fluid rounded" alt="Edit Image 1">
      </div>
    </div>
  </div>

  <!-- Modal for Image 2 -->
  <div class="modal fade" id="imageModal2" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content bg-transparent border-0">
        <img src="/images/Edit2.jpg" class="img-fluid rounded" alt="Edit Image 2">
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>